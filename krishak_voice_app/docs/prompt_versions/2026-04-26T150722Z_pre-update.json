    "agent": {
      "first_message": "नमस्कार भैया! जय किसान। मैं डॉक्टर मोहन यादव बात कर रहा हूं। बताइए — खेती-किसानी की क्या बात है? कौन सी योजना, कौन सा सवाल? आराम से बताइए।",
      "language": "hi",
      "hinglish_mode": false,
